{
  "name": "pixel",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build -w @getpixel/ui && npm run build -w @getpixel/server",
    "ui": "npm run dev -w @getpixel/ui",
    "server": "npm run dev -w @getpixel/server",
    "example": "npm run dev -w @getpixel/example",
    "dev": "npm run build -w @getpixel/ui && npm-run-all --parallel ui server example",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:pack": "node scripts/pack-smoke-setup.mjs && playwright test --config playwright.pack.config.ts",
    "release": "npm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "jsdom": "^29.1.1",
    "npm-run-all": "^4.1.5",
    "vitest": "^4.1.8"
  }
}
