{
  "name": "pixel",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build -w @getpixel/ui && npm run build -w @getpixel/server",
    "server": "npm run dev -w @getpixel/server",
    "example": "npm run dev -w @getpixel/example",
    "dev": "npm-run-all --parallel server example",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "release": "npm run build && npm publish -w @getpixel/ui -w @getpixel/server --access public"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "jsdom": "^29.1.1",
    "npm-run-all": "^4.1.5",
    "vitest": "^4.1.8"
  }
}
