{
  "name": "@getpixel/server",
  "version": "0.1.2",
  "description": "Standalone Node ingest for Pixel recordings: dropbox writer + Whisper transcription + correlation.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adamkleingit/pixel.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/adamkleingit/pixel#readme",
  "bugs": {
    "url": "https://github.com/adamkleingit/pixel/issues"
  },
  "type": "module",
  "bin": {
    "pixel-server": "./dist/index.js"
  },
  "files": [
    "dist",
    "skill"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && node scripts/bundle-skill.mjs",
    "start": "node dist/index.js",
    "dev": "SCREENSHARE_PORT=41889 SCREENSHARE_PROJECT_DIR=../../examples/basic tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "prepack": "cp ../../README.md README.md",
    "postpack": "rm -f README.md"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.3.3",
    "chokidar": "^4.0.3",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "ffmpeg-static": "^5.2.0",
    "multer": "^2.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  }
}
