{
  "name": "@getpixel/ui",
  "version": "0.1.1",
  "description": "In-page React SDK for recording a point-and-narrate session (audio + clicks + drag regions).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adamkleingit/pixel.git",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/adamkleingit/pixel#readme",
  "bugs": {
    "url": "https://github.com/adamkleingit/pixel/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepack": "cp ../../README.md README.md",
    "postpack": "rm -f README.md"
  },
  "dependencies": {
    "fix-webm-duration": "^1.0.5",
    "html-to-image": "^1.11.13"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
